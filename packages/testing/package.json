{
  "name": "@hathor/testing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hathor/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "@types/supertest": "7.2.1",
    "supertest": "7.2.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "2.1.9"
  }
}
