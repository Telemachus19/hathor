{
  "name": "@hathor/auth-service",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "tsx src/infrastructure/db/migrate.ts",
    "db:seed": "tsx src/infrastructure/db/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.0",
    "pg": "^8.12.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.20.18",
    "tsup": "^8.1.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0"
  }
}
